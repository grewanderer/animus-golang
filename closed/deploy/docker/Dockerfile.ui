FROM node:20.18.1-alpine AS build

WORKDIR /app

COPY closed/frontend_console/package.json closed/frontend_console/package-lock.json ./
RUN npm ci

COPY closed/frontend_console/ ./

ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:20.18.1-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=build /app ./

EXPOSE 3001
CMD ["npm", "run", "start", "--", "-p", "3001"]
